{
  "name": "famous-land-quest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "cf:build": "next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.0",
    "next": "^16.2.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.85.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
